{
  "name": "@prose-eng/html-to-pdfmake",
  "version": "2.5.33",
  "description": "Convert HTML to a pdfmake document definition",
  "type": "commonjs",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "browser": "dist/browser.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./browser": "./dist/browser.js",
    "./package.json": "./package.json"
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "bun run build.ts",
    "build:docs": "bun run update-doc.ts",
    "example": "bun run example.ts",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prose-Eng/html-to-pdfmake-v2.git"
  },
  "author": "Prose-Eng",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Prose-Eng/html-to-pdfmake-v2/issues"
  },
  "homepage": "https://github.com/Prose-Eng/html-to-pdfmake-v2#readme",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "@types/jsdom": "^21.1.7",
    "jsdom": "^25.0.1",
    "pdfmake": "^0.2.20",
    "svg-to-pdfkit": "^0.1.8",
    "typescript": "^5.7.2"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
